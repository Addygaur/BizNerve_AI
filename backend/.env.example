API_PORT=8080
DATABASE_URL=postgresql://postgres:postgres@db:5432/biznerve
AI_SERVICE_URL=http://ai:8000
MONTHLY_REVENUE_TARGET=1500000
# Revenue projection alert only from this day of month (e.g. 10 = after 10th).
REVENUE_ALERT_ONLY_FROM_DAY=10
# Z-score threshold for velocity alerts (only alert when |Z| > this). Default 2.5. Tune higher (e.g. 3) for fewer alerts.
VELOCITY_ZSCORE_THRESHOLD=2.5
# Margin erosion: alert when margin drops ≥ this many percentage points vs last month and revenue growth < MARGIN_EROSION_MAX_REVENUE_GROWTH_PCT.
MARGIN_EROSION_MIN_DROP_PCT=10
MARGIN_EROSION_MAX_REVENUE_GROWTH_PCT=5
# Run margin erosion alert only from this day of month (e.g. 25 = end-of-month only).
MARGIN_ALERT_ONLY_FROM_DAY=25
# Dead-stock: set both to use static values (no dynamic logic). Leave unset for auto tier-based behaviour.
# DEAD_STOCK_MIN_INVENTORY_VALUE=5000
# DEAD_STOCK_MAX_ALERTS=50
# Dead-stock dynamic guardrails (used when above are unset): floor/cap for min value, cap for max alerts.
# DEAD_STOCK_MIN_VALUE_FLOOR=2000
# DEAD_STOCK_MIN_VALUE_CAP=25000
# DEAD_STOCK_MAX_ALERTS_CAP=100
UPLOAD_LIMIT_MB=10
POSTGRES_DB=biznerve
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
